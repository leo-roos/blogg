{% for post in collections.posts reversed %}
    <div class="post">
        <h2 class="title">
            <a href="{{post.url}}">{{post.data.title}}</a>
        </h2>

        <div class="tags">
            {% for tag in post.data.tagList %}
            {% if tag == "posts" %}
                {% continue %}
            {% endif %}
                <a href="/tags/{{tag | slugify}}">{{tag}}</a>
            {% endfor %}
        </div>
        <p class="date">{{post.date | postDate }}</p>
    </div>
{% endfor %}